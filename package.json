{
  "name": "@arpadtamasi/a-team",
  "version": "0.1.1",
  "description": "Repository-native operating system for human-AI development teams",
  "homepage": "https://github.com/arpadtamasi/a-team#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arpadtamasi/a-team.git"
  },
  "bugs": {
    "url": "https://github.com/arpadtamasi/a-team/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "a-team": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "ui-dist",
    "profiles",
    "schemas",
    "skills",
    "templates"
  ],
  "scripts": {
    "build": "npm run build:cli && npm run build:ui",
    "build:cli": "node scripts/clean.mjs && tsc -p tsconfig.json",
    "build:ui": "vite build --config ui/vite.config.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "verify:pack": "npm run build && node scripts/verify-pack.mjs",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "gray-matter": "^4.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.8.0",
    "vite": "^7.3.6",
    "vitest": "^3.2.0"
  },
  "license": "MIT"
}
