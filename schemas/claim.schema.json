{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arpadtamasi/a-team/schemas/claim.schema.json",
  "title": "A-Team execution claim",
  "type": "object",
  "required": ["ticket", "agent", "branch", "worktree", "started_at"],
  "properties": {
    "ticket": { "type": "string", "pattern": "^(T-[0-9]{3,}|O-[0-9]+(?:\\.[0-9]+)?)$" },
    "agent": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1, "not": { "enum": ["main", "master", "develop"] } },
    "worktree": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:Z|[+-][0-9]{2}:[0-9]{2})$" },
    "session_id": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
