{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arpadtamasi/a-team/schemas/package.schema.json",
  "title": "A-Team package frontmatter",
  "type": "object",
  "required": ["id", "kind", "title", "status", "tickets", "execution", "authority", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^P-[0-9]{3,}$" },
    "kind": { "enum": ["sprint", "milestone", "batch", "mission"] },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["backlog", "ready", "active", "done"] },
    "tickets": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^T-[0-9]{3,}$" } },
    "execution": {
      "type": "object",
      "required": ["mode", "parallelism", "stop_on_failure"],
      "properties": {
        "mode": { "enum": ["sequential", "parallel", "dependency-aware"] },
        "parallelism": { "type": "integer", "minimum": 1 },
        "stop_on_failure": { "type": "boolean" }
      },
      "allOf": [{ "if": { "properties": { "mode": { "const": "sequential" } }, "required": ["mode"] }, "then": { "properties": { "parallelism": { "const": 1 } } } }],
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["create_findings", "create_subtickets", "reorder_independent_tickets", "change_scope"],
      "properties": {
        "create_findings": { "type": "boolean" },
        "create_subtickets": { "type": "boolean" },
        "reorder_independent_tickets": { "type": "boolean" },
        "change_scope": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "blocked": { "type": "boolean" },
    "blocked_reason": { "type": "string", "minLength": 1 },
    "created_at": { "$ref": "#/$defs/date" },
    "updated_at": { "$ref": "#/$defs/date" }
  },
  "$defs": { "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" } },
  "additionalProperties": false
}
