{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arpadtamasi/a-team/schemas/ticket.schema.json",
  "title": "A-Team ticket frontmatter",
  "type": "object",
  "required": ["id", "title", "status", "origin", "types", "profiles", "priority", "risk", "depends_on", "blocks", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^(T-[0-9]{3,}|O-[0-9]+(?:\\.[0-9]+)?)$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["backlog", "ready", "active", "review", "done"] },
    "origin": { "enum": ["human", "agent", "finding", "imported"] },
    "source_finding": { "type": "string", "pattern": "^(F-[0-9]{3,}|O-[0-9]+)$" },
    "types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "profiles": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "priority": { "enum": ["low", "medium", "high", "critical"] },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "package": { "oneOf": [{ "type": "null" }, { "type": "string", "pattern": "^P-[0-9]{3,}$" }] },
    "depends_on": { "$ref": "#/$defs/ticketIds" },
    "blocks": { "$ref": "#/$defs/ticketIds" },
    "branch": { "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }] },
    "pull_request": { "oneOf": [{ "type": "null" }, { "type": ["string", "integer"], "minLength": 1 }] },
    "assigned_agent": { "type": "string", "minLength": 1 },
    "blocked": { "type": "boolean" },
    "blocked_reason": { "type": "string", "minLength": 1 },
    "resolution": { "enum": ["completed", "cancelled", "duplicate", "obsolete"] },
    "created_at": { "$ref": "#/$defs/date" },
    "updated_at": { "$ref": "#/$defs/date" }
  },
  "allOf": [
    {
      "if": { "properties": { "blocked": { "const": true } }, "required": ["blocked"] },
      "then": { "required": ["blocked_reason"] }
    },
    {
      "if": { "properties": { "status": { "const": "active" } }, "required": ["status"] },
      "then": { "required": ["branch", "assigned_agent"], "properties": { "branch": { "type": "string", "minLength": 1 } } }
    },
    {
      "if": { "properties": { "status": { "const": "done" } }, "required": ["status"] },
      "then": { "required": ["resolution"] }
    }
  ],
  "$defs": {
    "ticketIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^(T-[0-9]{3,}|O-[0-9]+(?:\\.[0-9]+)?)$" } },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
  },
  "additionalProperties": false
}
